# =============================================================================
# Configuration du service MCP — Copier en .env et adapter
# =============================================================================

# --- Serveur MCP ---
MCP_SERVER_NAME=mon-mcp-service
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8002

# --- WAF ---
WAF_PORT=8082

# --- Auth ---
# Clé de bootstrap pour le premier accès admin.
# ⚠️  Changer en production ! (minimum 64 caractères aléatoires)
ADMIN_BOOTSTRAP_KEY=change_me_in_production

# --- S3 Token Store (optionnel) ---
# Si configuré, les tokens d'accès sont persistés sur S3.
# Si vide, seul le bootstrap key fonctionne (mode développement).
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION_NAME=fr1

# --- Vos services métier (exemples) ---
# DATABASE_URL=postgresql://user:pass@db:5432/mydb
# REDIS_URL=redis://redis:6379/0
# EXTERNAL_API_KEY=
# EXTERNAL_API_URL=https://api.example.com

# =============================================================================
# Configuration MCP Tools
# =============================================================================

# --- WAF (Caddy + Coraza) ---
WAF_PORT=8082

# --- Serveur MCP ---
MCP_SERVER_NAME=mcp-tools
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8050
MCP_SERVER_DEBUG=false

# --- Authentification ---
# Clé utilisée pour les requêtes administratives / bypass token S3
ADMIN_BOOTSTRAP_KEY=change_me_in_production

# --- Stockage S3 Dell ECS (Gestion tokens + Tool files) ---
# Dell ECS Cloud Temple : config hybride SigV2/SigV4 automatique
# SigV2 pour données (PUT/GET/DELETE), SigV4 pour métadonnées (HEAD/LIST)
# Le tool files utilise ces valeurs par défaut (overridable par paramètre)
S3_ENDPOINT_URL=https://s3.fr1.cloud-temple.com
S3_ACCESS_KEY_ID=AKIA_YOUR_KEY
S3_SECRET_ACCESS_KEY=your_secret
S3_BUCKET_NAME=mcp-tools
S3_REGION_NAME=fr1

# --- Perplexity ---
# Clé API pour les outils perplexity_*
PERPLEXITY_API_KEY=pplx_...
PERPLEXITY_MODEL=sonar-reasoning-pro
PERPLEXITY_API_URL=https://api.perplexity.ai

# --- Limites globales d'exécution ---
TOOL_MAX_OUTPUT_CHARS=50000
TOOL_MAX_CONCURRENT=20
TOOL_DEFAULT_TIMEOUT=60
TOOL_MAX_TIMEOUT=600

# --- Sandbox Docker (tool shell) ---
# Image Docker utilisée pour l'exécution isolée des commandes shell
SANDBOX_IMAGE=mcp-tools-sandbox
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=10
SANDBOX_TMPFS_SIZE=32m
SANDBOX_MAX_TIMEOUT=30
# Mettre à false pour exécuter en local (dev sans Docker)
SANDBOX_ENABLED=true
# DNS pour les conteneurs sandbox réseau (séparés par virgule)
# En production Cloud Temple : utiliser le DNS interne
SANDBOX_DNS=8.8.8.8,8.8.4.4

# --- Email (Phase 2 - Optionnel) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=mon_user
# SMTP_PASSWORD=mon_password
